            sep.style.cssText='width:1px;height:28px;background:rgba(255,255,255,0.08);flex-shrink:0;margin:0 2px;align-self:center';
            row.appendChild(sep);

            var mkNum=function(id,lbl,val){
              var w=document.createElement('div');
              w.style.cssText='flex:0 0 auto;min-width:50px;max-width:60px';
