#pragma once

/**
 * @file nina_client_internal.h
 * @brief Internal shared utilities for nina_client modules.
 *
 * Not part of the public API — only included by nina_client.c,
 * nina_api_fetchers.c, nina_sequence.c, and nina_websocket.c.
