            input.type='text';
            input.className='input';
            input.id=fieldId+'_'+inp;
            input.value=fData[inp]||'';
            input.style.cssText='min-height:36px;padding:6px 10px;font-size:0.78rem';
            if(inp==='key'){
              input.placeholder='e.g., data.cpu_temp';
              input.addEventListener('focus',function(){
                if(activeFieldInput) activeFieldInput.style.boxShadow='';
                activeFieldInput=this;
                this.style.boxShadow='0 0 0 2px rgba(59,130,246,0.4)';
              });
              input.addEventListener('blur',function(){
                var self=this;
                setTimeout(function(){
                  if(activeFieldInput===self){
                    self.style.boxShadow='';
                  }
                },200);
              });
            } else if(inp==='title'||inp==='label'){
              input.placeholder=inp==='title'?'Display title':'Label';
            } else if(inp==='unit'||inp==='suffix'){
              input.placeholder=inp==='unit'?'\u00b0C, %, etc.':'suffix';
              wrap.style.maxWidth='80px';
              wrap.style.minWidth='60px';
              wrap.style.flex='0 0 auto';
            } else if(inp==='on_value'){
              input.placeholder='On, Yes, etc.';
              wrap.style.maxWidth='100px';
              wrap.style.minWidth='80px';
              wrap.style.flex='0 0 auto';
            }
            wrap.appendChild(inpLabel);
            wrap.appendChild(input);
            row.appendChild(wrap);
          });

          /* Inline threshold/color controls for fields with unit or suffix */
          if(hasColorInputs(f)){
            var thrKey=quadDef.quad+'_'+f.key;
            var t=thresholds[thrKey]||{};
            var minVal=t.min!=null?t.min:(f.defMin!=null?f.defMin:'');
            var maxVal=t.max!=null?t.max:(f.defMax!=null?f.defMax:'');
            var minColor=t.color_min||(f.defMinColor||'#10b981');
            var maxColor=t.color_max||(f.defMaxColor||'#ef4444');

