    function renderJsonTree(obj,prefix){
      var html='';
      for(var key in obj){
        if(!obj.hasOwnProperty(key)) continue;
        var path=prefix?prefix+'.'+key:key;
        var val=obj[key];
        if(val!==null&&typeof val==='object'&&!Array.isArray(val)){
          html+='<details><summary style="cursor:pointer;color:#93c5fd;padding:2px 0;user-select:none">'+escHtml(key)+'</summary>';
          html+='<div style="padding-left:16px;border-left:1px solid rgba(255,255,255,0.06)">'+renderJsonTree(val,path)+'</div></details>';
        } else {
          var escapedPath=path.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
          html+='<div style="padding:3px 0;display:flex;justify-content:space-between;align-items:center;gap:8px">';
          html+='<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><span style="color:#d1d5db">'+escHtml(key)+'</span><span style="color:#71717a">: </span><span style="color:#fbbf24">'+escHtml(JSON.stringify(val))+'</span></span>';
          html+='<button onclick="selectJsonKey(\''+escapedPath+'\')" style="flex-shrink:0;font-size:0.6rem;padding:2px 10px;background:rgba(59,130,246,0.2);border:1px solid rgba(59,130,246,0.35);border-radius:4px;color:#93c5fd;cursor:pointer;font-family:inherit;transition:background 0.15s" onmouseover="this.style.background=\'rgba(59,130,246,0.35)\'" onmouseout="this.style.background=\'rgba(59,130,246,0.2)\'">Use</button>';
          html+='</div>';
        }
      }
      return html;
    }

    function escHtml(s){
