    /* === Config Load === */
    let loadedConfig='';
    let _populating=false;

    function populateConfig(data){
      _populating=true;
      $('hostname').value=data.hostname||'';
      var hn=data.hostname||'NINA Display';
      $('brandName').textContent=hn;
      document.title=hn;
      if(data.wifi_networks && data.wifi_networks.length) {
        for(var i=0;i<3;i++) {
          var n=data.wifi_networks[i]||{};
          $('ssid'+(i+1)).value=n.ssid||'';
          $('pass'+(i+1)).value='';
        }
      } else {
        $('ssid1').value=data.ssid||'';
        $('pass1').value='';
        $('ssid2').value='';$('pass2').value='';
        $('ssid3').value='';$('pass3').value='';
      }
      $('ntp').value=data.ntp||'';
      $('timezone').value=data.timezone||'';

      function extractHost(url){
        if(!url) return '';
        var m=url.match(/^https?:\/\/([^:/]+)/);
        return m?m[1]:'';
      }

      $('url1').value=extractHost(data.url1);
      $('url2').value=extractHost(data.url2);
      $('url3').value=extractHost(data.url3);

      $('theme_select').value=data.theme_index||0;
      $('widget_style_select').value=data.widget_style||0;
      $('screen_rotation_select').value=data.screen_rotation||0;
      var br=data.brightness!=null?data.brightness:80;
      $('brightness').value=br;
      $('brightness_val').textContent=br+'%';
      var cb=data.color_brightness!=null?data.color_brightness:80;
      $('color_brightness').value=cb;
      $('color_brightness_val').textContent=cb+'%';
      $('update_rate').value=data.update_rate_s||2;
      $('graph_interval').value=data.graph_update_interval_s||5;
      $('connection_timeout').value=data.connection_timeout_s||6;
      $('toast_duration').value=data.toast_duration_s||8;
      $('debug_mode').checked=!!data.debug_mode;
      $('demo_mode').checked=!!data.demo_mode;
      $('instance_enabled_0').checked=data.instance_enabled_1!==false;
      $('instance_enabled_1').checked=data.instance_enabled_2!==false;
      $('instance_enabled_2').checked=data.instance_enabled_3!==false;
      $('screen_sleep_enabled').checked=!!data.screen_sleep_enabled;
      $('screen_sleep_timeout').value=data.screen_sleep_timeout_s||60;
      $('idle_poll_interval').value=data.idle_poll_interval_s||30;
      $('wifi_power_save').checked=data.wifi_power_save!==false;
      $('deep_sleep_enabled').checked=!!data.deep_sleep_enabled;
      $('deep_sleep_wake_timer').value=Math.round((data.deep_sleep_wake_timer_s||0)/3600);
      $('deep_sleep_on_idle').checked=!!data.deep_sleep_on_idle;
      $('alert_flash_enabled').checked=data.alert_flash_enabled!==false;
      $('auto_update_check').checked=data.auto_update_check!==false;
      $('update_channel').value=data.update_channel||0;

      for(var i=0;i<3;i++){
        var key='filter_colors_'+(i+1);
        try{filterColorsArr[i]=data[key]?JSON.parse(data[key]):{};}catch(e){filterColorsArr[i]={};}
        renderFilterColors(i);
      }

      loadThresholds(data,0,'rms_thresholds_1','hfr_thresholds_1');
      loadThresholds(data,1,'rms_thresholds_2','hfr_thresholds_2');
      loadThresholds(data,2,'rms_thresholds_3','hfr_thresholds_3');

      var mqttUrl=data.mqtt_broker_url||'';
      var mqttMatch=mqttUrl.match(/^mqtt:\/\/(.+)/);
      $('mqtt_broker').value=mqttMatch?mqttMatch[1]:'';
      $('mqtt_port').value=data.mqtt_port||1883;
      $('mqtt_user').value=data.mqtt_username||'';
      $('mqtt_pass').value=data.mqtt_password||'';
      $('mqtt_prefix').value=data.mqtt_topic_prefix||'';
      $('mqtt_enabled').checked=!!data.mqtt_enabled;

      var pageMode='auto';
      if(data.auto_rotate_enabled) pageMode='rotate';
      else if(data.active_page_override!=null&&data.active_page_override>=0) pageMode='fixed';

      $('auto_rotate_interval').value=data.auto_rotate_interval_s||30;
      $('auto_rotate_effect').value=data.auto_rotate_effect||0;
      $('auto_rotate_skip').checked=!!data.auto_rotate_skip_disconnected;
      setRotatePages(data.auto_rotate_pages!=null?data.auto_rotate_pages:0x1F);

      updateNodeLabels();

      // passwords cleared in populateConfig wifi_networks block above

      // AllSky fields
      if($('allsky_enabled')) $('allsky_enabled').checked=!!data.allsky_enabled;
      if($('allskyHostname')) $('allskyHostname').value=data.allsky_hostname||'';
      if($('allskyInterval')) $('allskyInterval').value=data.allsky_update_interval_s||5;
      if($('allskyDewOffset')) $('allskyDewOffset').value=data.allsky_dew_offset!=null?data.allsky_dew_offset:5.0;
      var asThr={};
      try{ asThr=JSON.parse(data.allsky_thresholds||'{}'); }catch(e){}
      var asFields={};
      try{ asFields=JSON.parse(data.allsky_field_config||'{}'); }catch(e){}
      populateAllSkyFieldMappings(asFields,asThr);
      updateAllSkyEnabledUI();

      // Spotify fields
      if($('spotify_enabled')) $('spotify_enabled').checked=!!data.spotify_enabled;
      if($('spotifyClientId')) $('spotifyClientId').value=data.spotify_client_id||'';
      if($('spotifyPollInterval')) $('spotifyPollInterval').value=data.spotify_poll_interval_ms||3000;
      if($('spotify_show_progress_bar')) $('spotify_show_progress_bar').checked=data.spotify_show_progress_bar!=null?!!data.spotify_show_progress_bar:true;
      if($('spotify_minimal_mode')) $('spotify_minimal_mode').checked=!!data.spotify_minimal_mode;
      if($('spotify_scroll_text')) $('spotify_scroll_text').checked=data.spotify_scroll_text!=null?!!data.spotify_scroll_text:true;
      if($('spotifyOverlayTimeout')) $('spotifyOverlayTimeout').value=data.spotify_overlay_timeout_s!=null?data.spotify_overlay_timeout_s:5;
      updateSpotifyEnabledUI();

      /* Backup tab version info */
      if ($('backupCurrentVersion')) $('backupCurrentVersion').textContent = 'v' + (data.config_version || '?');
      if ($('backupFirmwareVersion')) {
        fetch('/api/version').then(function(r){return r.json()}).then(function(v){
          $('backupFirmwareVersion').textContent = v.git_tag || '--';
        }).catch(function(){});
      }

      // Update page selector AFTER all enable checkboxes are populated
      updatePageSelectOptions();
      $('active_page').value=(data.active_page_override!=null&&data.active_page_override>=0)?''+data.active_page_override:'1';
      setPageMode(pageMode);

      loadedConfig=JSON.stringify(getConfigData());
      _populating=false;
      if(data._dirty){
        loadedConfig='';
      }
      checkDirty();
    }

    function loadConfig(){
      fetch('/api/config').then(r=>r.json()).then(populateConfig).catch(e=>console.error('Failed to load config',e));
    }

    /* === Version Load === */
    function loadVersion(){
      fetch('/api/version').then(r=>r.json()).then(data=>{
        $('fw_version').textContent=data.version||'--';
        $('fw_date').textContent=(data.date||'--')+' '+(data.time||'');
        $('fw_idf').textContent=data.idf||'--';
        $('fw_partition').textContent=data.partition||'--';

        var ghBase='https://github.com/chvvkumar/ESP32-P4-NINA-Display/';
        var tagEl=$('fw_git_tag');
        tagEl.textContent='';
        if(data.git_tag&&data.git_tag!=='unknown'){
          var a=document.createElement('a');
          a.href=ghBase+'releases/tag/'+encodeURIComponent(data.git_tag);
          a.target='_blank'; a.rel='noopener'; a.className='accent-link';
          a.textContent=data.git_tag;
          tagEl.appendChild(a);
        }else{
          tagEl.textContent=data.git_tag||'--';
        }

        var shaEl=$('fw_git_sha');
        shaEl.textContent='';
        if(data.git_sha&&data.git_sha!=='unknown'){
          var a=document.createElement('a');
          a.href=ghBase+'commit/'+encodeURIComponent(data.git_sha);
          a.target='_blank'; a.rel='noopener'; a.className='mono-link';
          a.textContent=data.git_sha.substring(0,8);
          shaEl.appendChild(a);
        }else{
          shaEl.textContent=data.git_sha||'--';
        }
      }).catch(e=>console.error('Failed to load version',e));
    }

    /* === Toast === */
    function showToast(msg,type){
      var t=$('toast');
      t.textContent=msg;
      t.className='toast '+(type||'')+' show';
      clearTimeout(t._timer);
      t._timer=setTimeout(()=>{t.classList.remove('show');},3000);
    }

    /* === Save / Discard / Reboot / Reset === */
    function save(){
      var btn=$('saveBtn');
      btn.disabled=true; btn.textContent='Saving...';
      postJson('/api/config',getConfigData()).then(r=>{
        if(!r.ok) throw new Error('Save failed');
        return r.text();
      }).then(()=>{
        showToast('Settings saved','success');
        loadedConfig=JSON.stringify(getConfigData());
        $('saveBar').classList.remove('visible');
      }).catch(e=>{
        showToast('Save failed: '+e.message,'error');
      }).finally(()=>{
        btn.disabled=false; btn.textContent='Save';
      });
    }

    function reloadConfig(){
      fetch('/api/config/revert',{method:'POST'}).then(r=>{
        if(!r.ok) throw new Error('Revert failed');
        loadConfig();
        $('saveBar').classList.remove('visible');
      }).catch(e=>showToast('Discard failed: '+e.message,'error'));
    }

    function saveAndReboot(){
      if(!confirm('Apply changes and reboot now?')) return;
      postJson('/api/config',getConfigData()).then(r=>{
        if(!r.ok) throw new Error('Save failed');
        return fetch('/api/reboot',{method:'POST'});
      }).then(()=>{
        showToast('Rebooting...','success');
      }).catch(e=>{
        showToast('Error: '+e.message,'error');
      });
    }

    function factoryReset(){
      if(!confirm('Wipe all settings?')) return;
      if(!confirm('Confirm Reset?')) return;
      fetch('/api/factory-reset',{method:'POST'}).then(()=>{
        showToast('Factory reset. Rebooting...','success');
      }).catch(e=>{
        showToast('Reset failed: '+e.message,'error');
      });
    }

    /* === OTA === */
    function otaFileSelected(input){
      var label=$('otaFileLabel');
      if(input.files.length>0){
        label.textContent=input.files[0].name;
        label.classList.add('has-file');
        label.appendChild(input);
        $('otaBtn').disabled=false;
      }else{
        label.textContent='Choose firmware .bin file';
        label.classList.remove('has-file');
        label.appendChild(input);
        $('otaBtn').disabled=true;
      }
    }

    function checkForUpdates(){
      var btn=$('checkUpdateBtn');
      btn.disabled=true; btn.textContent='Checking...';
      fetch('/api/check-update',{method:'POST'}).then(()=>{
        btn.textContent='Check requested \u2014 see device screen';
        setTimeout(()=>{btn.disabled=false;btn.textContent='Check for Updates';},5000);
      }).catch(()=>{
        btn.disabled=false; btn.textContent='Check for Updates';
        alert('Failed to reach device');
      });
    }

    function startOta(){
      var fileInput=$('otaFile');
      if(!fileInput.files.length) return;
      if(!confirm('Flash new firmware? The device will reboot after update.')) return;
      var file=fileInput.files[0];
      var progressDiv=$('otaProgress');
      var fill=$('otaProgressFill');
      var status=$('otaStatus');
      var btn=$('otaBtn');
      progressDiv.style.display='block';
      btn.disabled=true;
      fill.style.width='0%';
      status.textContent='Uploading...';
      var xhr=new XMLHttpRequest();
      xhr.open('POST','/api/ota',true);
      xhr.setRequestHeader('Content-Type','application/octet-stream');
      xhr.upload.addEventListener('progress',function(e){
        if(e.lengthComputable){
          var pct=Math.round((e.loaded/e.total)*100);
          fill.style.width=pct+'%';
          status.textContent='Uploading... '+pct+'%';
        }
      });
      xhr.addEventListener('load',function(){
        if(xhr.status>=200&&xhr.status<300){
          fill.style.width='100%';
          status.textContent='Update complete! Rebooting...';
          showToast('Firmware updated. Rebooting...','success');
        }else{
          status.textContent='Update failed (HTTP '+xhr.status+')';
          showToast('OTA failed','error');
          btn.disabled=false;
        }
      });
      xhr.addEventListener('error',function(){
        status.textContent='Upload error';
        showToast('OTA upload error','error');
        btn.disabled=false;
      });
      xhr.send(file);
    }

    /* === Screenshot === */
    function takeScreenshot(){
      var btn=$('ssBtn');
      btn.disabled=true; btn.textContent='Capturing...';
      fetch('/api/screenshot').then(function(r){
        if(!r.ok) throw new Error('Screenshot failed');
        return r.blob();
      }).then(function(blob){
        var url=URL.createObjectURL(blob);
        var img=$('ssImage');
        if(img._prevUrl) URL.revokeObjectURL(img._prevUrl);
        img._prevUrl=url;
        img.src=url;
        $('ssContainer').style.display='block';
        btn.textContent='Capture Screenshot'; btn.disabled=false;
      }).catch(function(e){
        showToast('Screenshot failed','error');
        btn.textContent='Capture Screenshot'; btn.disabled=false;
      });
    }

    /* === Dirty State Detection === */
    function checkDirty(){
      if(_populating) return;
      var dirty=JSON.stringify(getConfigData())!==loadedConfig;
      $('saveBar').classList.toggle('visible',dirty);
    }

    /* === Live Apply (Debounced) === */
    let _applyTimer=null;
    function liveApply(){
      if(_populating) return;
      clearTimeout(_applyTimer);
      _applyTimer=setTimeout(()=>{
        var data=getConfigData();
        if(data.wifi_networks){
          data.wifi_networks.forEach(function(n){delete n.pass;});
        }
        delete data.ssid;
        delete data.pass;
        postJson('/api/config/apply',data).catch(e=>console.error('Live apply failed:',e));
      },400);
    }

    document.querySelector('.content').addEventListener('input',()=>{checkDirty();liveApply();});
    document.querySelector('.content').addEventListener('change',()=>{checkDirty();liveApply();});

    /* === Spotify Configuration === */

    function generateRandomString(length){
      var possible='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
      var values=crypto.getRandomValues(new Uint8Array(length));
      return Array.from(values).map(function(x){return possible[x%possible.length]}).join('');
    }

    /* Pure-JS SHA-256 — works over plain HTTP (no crypto.subtle needed) */
    function sha256(plain){
      function rr(v,n){return(v>>>n)|(v<<(32-n))}
      var K=[0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,
        0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,
        0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,
        0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,
        0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,
        0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,
        0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,
        0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2];
      var H=[0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19];
      var enc=new TextEncoder(),bytes=enc.encode(plain),bl=bytes.length*8;
      var pad=new Uint8Array(((bytes.length+9+63)&~63));
      pad.set(bytes);pad[bytes.length]=0x80;
      var dv=new DataView(pad.buffer);dv.setUint32(pad.length-4,bl,false);
      for(var off=0;off<pad.length;off+=64){
        var W=new Array(64),i;
        for(i=0;i<16;i++)W[i]=dv.getUint32(off+i*4,false);
        for(i=16;i<64;i++){var s0=rr(W[i-15],7)^rr(W[i-15],18)^(W[i-15]>>>3),s1=rr(W[i-2],17)^rr(W[i-2],19)^(W[i-2]>>>10);W[i]=(W[i-16]+s0+W[i-7]+s1)|0;}
        var a=H[0],b=H[1],c=H[2],d=H[3],e=H[4],f=H[5],g=H[6],h=H[7];
        for(i=0;i<64;i++){var S1=rr(e,6)^rr(e,11)^rr(e,25),ch=(e&f)^(~e&g),t1=(h+S1+ch+K[i]+W[i])|0,S0=rr(a,2)^rr(a,13)^rr(a,22),mj=(a&b)^(a&c)^(b&c),t2=(S0+mj)|0;h=g;g=f;f=e;e=(d+t1)|0;d=c;c=b;b=a;a=(t1+t2)|0;}
        H[0]=(H[0]+a)|0;H[1]=(H[1]+b)|0;H[2]=(H[2]+c)|0;H[3]=(H[3]+d)|0;H[4]=(H[4]+e)|0;H[5]=(H[5]+f)|0;H[6]=(H[6]+g)|0;H[7]=(H[7]+h)|0;
      }
      var out=new Uint8Array(32);var ov=new DataView(out.buffer);
      for(var j=0;j<8;j++)ov.setUint32(j*4,H[j],false);
      return Promise.resolve(out.buffer);
    }

    function base64urlencode(arrayBuffer){
      var str=String.fromCharCode.apply(null,new Uint8Array(arrayBuffer));
      return btoa(str).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');
    }

    function spotifyLogin(){
      var clientId=$('spotifyClientId').value.trim();
      if(!clientId){showToast('Enter a Client ID first','error');return;}
      /* Auto-save client ID to device so token exchange can find it */
      fetch('/api/spotify/config',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({spotify_client_id:clientId,spotify_enabled:true})});
      var codeVerifier=generateRandomString(128);
      sessionStorage.setItem('spotify_code_verifier',codeVerifier);
      /* Use http://127.0.0.1:8000/callback — Spotify allows http for loopback IPs.
       * After auth, Spotify redirects to 127.0.0.1 which won't load — user pastes
       * the resulting URL back here so we can extract the auth code. */
      var redirectUri='http://127.0.0.1:8000/callback';
      sessionStorage.setItem('spotify_redirect_uri',redirectUri);
      sha256(codeVerifier).then(function(hashed){
        var codeChallenge=base64urlencode(hashed);
        var scopes='user-read-currently-playing user-read-playback-state user-modify-playback-state';
        var state=generateRandomString(16);
        sessionStorage.setItem('spotify_auth_state',state);
        var params=new URLSearchParams({
          response_type:'code',
          client_id:clientId,
          scope:scopes,
          redirect_uri:redirectUri,
          state:state,
          code_challenge_method:'S256',
          code_challenge:codeChallenge
        });
        window.open('https://accounts.spotify.com/authorize?'+params.toString(),'_blank');
        /* Show the paste-URL field */
        var pasteDiv=$('spotifyPasteDiv');
        if(pasteDiv) pasteDiv.style.display='block';
      });
    }
    function spotifySubmitCallback(){
      var urlStr=$('spotifyPasteUrl').value.trim();
      if(!urlStr){showToast('Paste the redirect URL first','error');return;}
      try{
        var u=new URL(urlStr);
        var code=u.searchParams.get('code');
        var cbState=u.searchParams.get('state');
        var error=u.searchParams.get('error');
        if(error){showToast('Spotify login denied: '+error,'error');return;}
        var savedState=sessionStorage.getItem('spotify_auth_state');
        if(cbState!==savedState){showToast('Auth state mismatch — please retry login','error');return;}
        if(!code){showToast('No auth code found in URL','error');return;}
        var cv=sessionStorage.getItem('spotify_code_verifier');
        var ru=sessionStorage.getItem('spotify_redirect_uri');
        $('spotifySubmitBtn').disabled=true;
        $('spotifySubmitBtn').textContent='Connecting...';
        fetch('/api/spotify/token-exchange',{
          method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({code:code,code_verifier:cv,redirect_uri:ru})
        }).then(function(r){return r.json()})
          .then(function(j){
            $('spotifySubmitBtn').disabled=false;
            $('spotifySubmitBtn').textContent='Submit';
            if(j.success){
              showToast('Spotify connected!','success');
              updateSpotifyStatus();
              $('spotifyPasteDiv').style.display='none';
              $('spotifyPasteUrl').value='';
            } else showToast('Token exchange failed: '+(j.error||'unknown'),'error');
          }).catch(function(e){
            $('spotifySubmitBtn').disabled=false;
            $('spotifySubmitBtn').textContent='Submit';
            showToast('Login error: '+e.message,'error');
          });
        sessionStorage.removeItem('spotify_code_verifier');
        sessionStorage.removeItem('spotify_auth_state');
        sessionStorage.removeItem('spotify_redirect_uri');
      }catch(e){showToast('Invalid URL — paste the full address bar URL','error');}
    }

    function spotifyLogout(){
      fetch('/api/spotify/logout',{method:'POST'})
        .then(function(r){
          if(!r.ok) throw new Error('Logout failed');
          showToast('Logged out of Spotify','info');
          updateSpotifyStatus();
        })
        .catch(function(e){showToast('Logout failed: '+e.message,'error');});
    }

    function updateSpotifyStatus(){
      fetch('/api/spotify/status')
        .then(function(r){return r.json();})
        .then(function(data){
          var el=$('spotifyStatus');
          var loginBtn=$('spotifyLoginBtn');
          var logoutBtn=$('spotifyLogoutBtn');
          if(!el) return;
          if(data.auth_state==='authorized'){
            el.textContent='Connected';
            el.style.color='#10b981';
            if(loginBtn) loginBtn.style.display='none';
            if(logoutBtn) logoutBtn.style.display='';
          } else if(data.auth_state==='error'){
            el.textContent='Error: '+(data.error||'Token refresh failed');
            el.style.color='#ef4444';
            if(loginBtn) loginBtn.style.display='';
            if(logoutBtn) logoutBtn.style.display='';
          } else {
            el.textContent='Not connected';
            el.style.color='#71717a';
            if(loginBtn) loginBtn.style.display='';
            if(logoutBtn) logoutBtn.style.display='none';
          }
        })
        .catch(function(){
          var el=$('spotifyStatus');
          if(el){el.textContent='Unable to check status';el.style.color='#71717a';}
        });
    }

