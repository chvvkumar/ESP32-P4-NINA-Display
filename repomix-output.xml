    lv_obj_set_flex_grow(sc->stats_row, 1);
    lv_obj_set_flex_align(sc->stats_row, LV_FLEX_ALIGN_SPACE_BETWEEN,
                          LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER);

    /* Safety icon column (first in stats row) */
