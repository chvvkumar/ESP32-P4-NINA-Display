/* ── Helpers ────────────────────────────────────────────────────────── */

/* Dim a color to ~30% brightness for bar track / glow */
static uint32_t dim_color(uint32_t c) {
    uint8_t r = ((c >> 16) & 0xFF) * 30 / 100;
    uint8_t g = ((c >> 8)  & 0xFF) * 30 / 100;
    uint8_t b = ((c)       & 0xFF) * 30 / 100;
    return ((uint32_t)r << 16) | ((uint32_t)g << 8) | b;
}

