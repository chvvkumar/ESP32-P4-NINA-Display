#include <string.h>

/* ── Static widget references ───────────────────────────────────────── */
static lv_obj_t *tab_root = NULL;

/* Appearance */
static lv_obj_t *dd_theme = NULL;
static lv_obj_t *dd_widget_style = NULL;
static lv_obj_t *slider_text_bright = NULL;
static lv_obj_t *lbl_text_bright_val = NULL;
