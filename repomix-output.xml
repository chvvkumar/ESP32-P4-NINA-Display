#define INFO_CARD_ROW_GAP  8
#define INFO_BACK_BTN_W   84
#define INFO_BACK_BTN_H   108
#define INFO_BACK_BTN_ZONE (INFO_BACK_BTN_W + 8)  /* right-side exclusion for bottom rows */

