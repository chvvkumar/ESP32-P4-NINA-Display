                lv_color_hex(app_config_apply_brightness(current_theme->text_color, gb)), 0);
            lv_obj_set_style_border_color(dd_timezone, lv_color_hex(current_theme->bento_border), 0);
            lv_obj_set_style_border_width(dd_timezone, 1, 0);
