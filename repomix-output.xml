    .ota-bar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-top: 20px; }
    .progress-bg { background: rgba(255, 255, 255, 0.06); border-radius: 6px; height: 8px; overflow: hidden; }
    .progress-fill {
