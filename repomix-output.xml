          var fData=(qData[f.key])||{};
          var fieldId='as_fm_'+quadDef.quad+'_'+f.key;
          var row=document.createElement('div');
          row.style.cssText='display:flex;flex-wrap:wrap;gap:8px;align-items:flex-end;margin-bottom:10px;padding:8px 0';

          var lbl=document.createElement('div');
          lbl.style.cssText='width:80px;flex-shrink:0;font-size:0.75rem;color:var(--text-muted);font-weight:500;padding-bottom:6px';
          lbl.textContent=f.label;
          row.appendChild(lbl);

          f.inputs.forEach(function(inp){
            var wrap=document.createElement('div');
            wrap.style.cssText='flex:1;min-width:100px';
