            lbl_hfr_sd_val = lv_label_create(block);
            lv_label_set_text(lbl_hfr_sd_val, "--");
            lv_obj_set_style_text_font(lbl_hfr_sd_val, &lv_font_montserrat_28, 0);
            if (current_theme)
                lv_obj_set_style_text_color(lbl_hfr_sd_val,
