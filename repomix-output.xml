            inpLabel.style.cssText='font-size:0.6rem;color:#71717a;margin-bottom:3px;text-transform:uppercase;letter-spacing:0.05em';
            inpLabel.textContent=inp==='key'?'JSON Key Path':inp==='on_value'?'On Value':inp.charAt(0).toUpperCase()+inp.slice(1);
