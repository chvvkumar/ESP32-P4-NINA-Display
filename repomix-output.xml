    function gatherAllSkyThresholds(){
      var result={};
      allskyFieldDefs.forEach(function(quadDef){
        quadDef.fields.forEach(function(f){
          if(!hasColorInputs(f)) return;
          var thrKey=quadDef.quad+'_'+f.key;
          var elMin=$('as_thr_'+thrKey+'_min');
          var elMax=$('as_thr_'+thrKey+'_max');
          if(!elMin||!elMax) return;
          var mn=elMin.value,mx=elMax.value;
          if(mn===''&&mx==='') return;
          result[thrKey]={
            min:parseFloat(mn)||0,
            max:parseFloat(mx)||0,
            color_min:$('as_thr_'+thrKey+'_minc').value,
            color_max:$('as_thr_'+thrKey+'_maxc').value
          };
        });
      });
      return result;
    }

    function gatherAllSkyFieldMappings(){
      var config={};
      allskyFieldDefs.forEach(function(quadDef){
        var qData={};
        quadDef.fields.forEach(function(f){
          var fieldId='as_fm_'+quadDef.quad+'_'+f.key;
          var fData={};
          var hasData=false;
          f.inputs.forEach(function(inp){
            var el=$(fieldId+'_'+inp);
